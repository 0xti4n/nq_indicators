               "Includes action, ticker, tf, price, score, sl, tp1-tp3, rr")

flipAlertInput = input.bool(true, "Alert on Trend Flips", group = GRP_ALERT,
     tooltip = "Informational flip alerts for flips that did not open or\n" +
               "reverse a trade. Conservative ATR mode ignores reversals\n" +
               "while a trade is open.\n" +
