               "Conservative ATR uses Band 20 trailing instead of BE.\n" +
               "Positions stopped at break-even after TP1 count as wins")

showSlTpInput = input.bool(true, "Show SL/TP Lines", group = GRP_RISK,
     tooltip = "Draw entry/SL/TP lines on chart after entry.\n" +
               "SL / BE / trailing stop clears the guide. Other closures\n" +
               "stay extended and are replaced on the next entry")

showSlTpLabelsInput = input.bool(true, "Show SL/TP Labels", group = GRP_RISK,
     tooltip = "Show price labels on SL/TP lines")

showPctOnLabelsInput = input.bool(true, "Show % Distance on Labels", group = GRP_RISK,
