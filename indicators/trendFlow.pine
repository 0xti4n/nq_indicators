//@version=6
// ══════════════════════════════════════════════════════════
// TRENDFLOW
// ══════════════════════════════════════════════════════════
// Version: 1.3.0

indicator(
     title            = "TrendFlow",
     shorttitle       = "TFLOW",
     overlay          = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_boxes_count  = 500,
     max_bars_back    = 5000)

// ══════════════════════════════════════════════════════════
// 2. CONSTANTS
// ══════════════════════════════════════════════════════════
GRP_MAIN   = "⚙️ Trend Engine"
GRP_SIG    = "🎯 Signals"
GRP_PROF   = "📦 Volume Profile"
GRP_VISUAL = "🎨 Visual Settings"
GRP_RISK   = "🛡️ Risk Management"
GRP_DASH   = "📊 Dashboard"
GRP_ALERT  = "🔔 Alerts"
GRP_COLORS = "🎨 Colors"
GRP_ADV    = "🔧 Advanced"

INDICATOR_VERSION = "v1.3.0"
LINE_FORWARD_BARS = 20
LINE_UPDATE_BARS  = 5
LABEL_OFFSET_BARS = 1
BE_DIM_TRANSP     = 70
FORM_LEN          = 10    // recent-form strip length

// ══════════════════════════════════════════════════════════
// 3. INPUTS
// ══════════════════════════════════════════════════════════

// ── Trend Engine ────────────────────────────────────────────
bandPresetInput = input.string("Balanced", "Band Width Preset",
     options = ["Scalping", "Balanced", "Deep Trend", "Custom"],
     group   = GRP_MAIN,
     tooltip = "Quick presets for band geometry:\n" +
               "• Scalping: tight bands (2.5×ATR base), fast flips, 1-15M charts\n" +
               "• Balanced: 4.0×ATR base, works on most timeframes\n" +
               "• Deep Trend: wide bands (6.0×ATR base), position trading, D-W\n" +
               "• Custom: use manual Base Multiplier / Band Spacing below")

baseMultInput = input.float(5.0, "Base Multiplier (×ATR)", minval = 0.5, maxval = 15.0, step = 0.1,
     group   = GRP_MAIN,
     tooltip = "Distance of the innermost band from price, in ATR units.\n" +
               "Only active when Preset = Custom.\n" +
               "• Lower = tighter trail, earlier flips, more noise\n" +
               "• Higher = wider trail, later flips, fewer whipsaws\n" +
               "• Recommended: 2.5-6.0")

bandStepInput = input.float(0.25, "Band Spacing (proportional step)", minval = 0.05, maxval = 1.0, step = 0.05,
     group   = GRP_MAIN,
     tooltip = "Proportional spacing between bands: band K = base × (1 + K×step).\n" +
               "Unlike fixed +1/+2/+3 offsets, spacing scales with the base multiplier\n" +
               "so band geometry stays consistent at any width.\n" +
               "Only active when Preset = Custom. Recommended: 0.2-0.35")

atrLenInput = input.int(13, "ATR Length", minval = 5, maxval = 100,
     group   = GRP_MAIN,
     tooltip = "Lookback period for the ATR that drives band width.\n" +
               "• 14 = standard\n" +
               "• Lower = more reactive bands\n" +
               "• Higher = smoother, more stable bands")

srcInput = input.source(close, "Source",
     group   = GRP_MAIN,
     tooltip = "Price source used for trailing and flip detection.\n" +
               "Close (default) is the most robust; HL2 reacts slightly faster")

engineTfInput = input.timeframe("", "Engine Timeframe",
     group   = GRP_MAIN,
     tooltip = "Timeframe used for the trend engine's source and ATR bands.\n" +
               "Leave empty to use the chart timeframe.\n" +
               "Example: chart 2m with Engine Timeframe = 15 calculates\n" +
               "TrendFlow bands/flips from 15m data")

flipBandStr = input.string("Balanced (Band 3)", "Flip Band",
     options = ["Fast (Band 2)", "Balanced (Band 3)", "Deep (Band 4)", "Extreme (Band 5)", "Maximum (Band 6)", "Band 7", "Band 8", "Band 9", "Band 10", "Band 11", "Band 12", "Band 13", "Band 14", "Band 15", "Band 16", "Band 17", "Band 18", "Band 19", "Band 20"],
     group   = GRP_MAIN,
     tooltip = "Which band a close must breach to flip the trend.\n" +
               "• Fast (Band 2): earliest flips, more signals, more noise\n" +
               "• Balanced (Band 3): recommended default\n" +
               "• Deep (Band 4): only major reversals flip the trend\n" +
               "• Extreme (Band 5): wider confirmation\n" +
               "• Maximum (Band 6): very wide confirmation\n" +
               "• Bands 7-20: progressively wider confirmations")

htfInput = input.timeframe("", "Higher Timeframe Bias",
     group   = GRP_MAIN,
     tooltip = "HTF used for bias scoring (EMA-50 direction on that timeframe).\n" +
               "Leave empty to use the chart timeframe.\n" +
               "Example: set 1H while trading 15M.\n" +
               "Separate from Engine Timeframe.\n" +
               "Non-repainting: uses closed HTF bars only")

// ── Signals ─────────────────────────────────────────────────
minScoreInput = input.int(80, "Min Retest Score (0-100)", minval = 0, maxval = 100,
     group   = GRP_SIG,
     tooltip = "Quality threshold for retest signals.\n" +
               "Score components: pullback depth (25), reclaim candle (20),\n" +
               "volume (20), HTF bias (20), trend age (15).\n" +
               "• 40-50 = more signals\n" +
               "• 55 = balanced (recommended)\n" +
               "• 70+ = only premium setups")

retestWindowInput = input.int(8, "Retest Window (bars)", minval = 1, maxval = 30,
     group   = GRP_SIG,
     tooltip = "After price touches a band, how many bars the reclaim\n" +
               "(close back above/below Band 1) remains valid.\n" +
               "Recommended: 5-10")

cooldownInput = input.int(5, "Signal Cooldown (bars)", minval = 0, maxval = 100,
     group   = GRP_SIG,
     tooltip = "Minimum bars between consecutive retest signals.\n" +
               "Prevents signal clusters during choppy pullbacks.\n" +
               "Shared across directions by design (anti-whipsaw).\n" +
               "Recommended: 3-10")

// ── Volume Profile ──────────────────────────────────────────
showProfileInput = input.bool(true, "Show Segment Volume Profile", group = GRP_PROF,
     tooltip = "Volume profile of the CURRENT trend segment only.\n" +
               "Bar volume is distributed proportionally across every price bin\n" +
               "the bar's high-low range overlaps — not dumped into one close-price\n" +
               "bin. On zero-volume symbols (forex) a range-weighted proxy is used")

profRowsInput = input.int(30, "Profile Rows", minval = 10, maxval = 100, group = GRP_PROF,
     tooltip = "Vertical resolution of the profile.\n" +
               "• 20-30 = clean structure (recommended)\n" +
               "• 50+ = fine detail, needs longer segments")

profWidthInput = input.int(34, "Profile Width (bars)", minval = 10, maxval = 100, group = GRP_PROF,
     tooltip = "Maximum horizontal width of the histogram, in chart bars")

maxProfBarsInput = input.int(500, "Max Profile Bars", minval = 50, maxval = 2000, group = GRP_PROF,
     tooltip = "Hard cap on how many bars of the segment are accumulated.\n" +
               "Keeps performance bounded on very old trends.\n" +
               "Recommended: 300-800")

showPocInput = input.bool(true, "Show POC", group = GRP_PROF,
     tooltip = "Point of Control — the price bin with the highest traded volume\n" +
               "in the current trend segment. Strongest magnet/defense level")

showVaInput = input.bool(true, "Show Value Area (70%)", group = GRP_PROF,
     tooltip = "Value Area — the price range containing 70% of segment volume,\n" +
               "expanded symmetrically from POC. Edges (VAH/VAL) act as S/R")

profLabelSizeInput = input.string("Small", "Profile Label Size",
     options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GRP_PROF,
     tooltip = "Font size for POC and LVN labels on the profile")

showNodesInput = input.bool(true, "Show HVN / LVN Levels", group = GRP_PROF,
     tooltip = "HVN (High Volume Nodes) — local volume peaks: acceptance zones,\n" +
               "price tends to stall there.\n" +
               "LVN (Low Volume Nodes) — volume gaps inside the Value Area:\n" +
               "price tends to travel through them quickly")

// ── Visual ──────────────────────────────────────────────────
themeInput = input.string("Auto", "Theme",
     options = ["Auto", "Dark", "Light"],
     group   = GRP_VISUAL,
     tooltip = "Chart color theme.\n" +
               "• Auto: detects from chart background\n" +
               "• Dark: optimized for dark backgrounds\n" +
               "• Light: optimized for light/white backgrounds")

showBandsInput = input.bool(true, "Show Trail Bands", group = GRP_VISUAL,
     tooltip = "Master switch for trailing band lines. Individual band toggles below only affect plots, not calculations")

showBand1Input = input.bool(true, "Band 1", inline = "bandPlots1", group = GRP_VISUAL,
     tooltip = "Show/hide Band 1 plot only. Calculations, signals and risk logic still use the band")
showBand2Input = input.bool(true, "Band 2", inline = "bandPlots1", group = GRP_VISUAL,
     tooltip = "Show/hide Band 2 plot only. Calculations, signals and risk logic still use the band")
showBand3Input = input.bool(true, "Band 3", inline = "bandPlots1", group = GRP_VISUAL,
     tooltip = "Show/hide Band 3 plot only. Calculations, signals and risk logic still use the band")
showBand4Input = input.bool(true, "Band 4", inline = "bandPlots1", group = GRP_VISUAL,
     tooltip = "Show/hide Band 4 plot only. Calculations and signals still use the band")
showBand5Input = input.bool(true, "Band 5", inline = "bandPlots1", group = GRP_VISUAL,
     tooltip = "Show/hide Band 5 plot only. Calculations and optional deep flips still use the band")
showBand6Input = input.bool(true, "Band 6", inline = "bandPlots2", group = GRP_VISUAL,
     tooltip = "Show/hide Band 6 plot only. Calculations and optional maximum flips still use the band")
showBand7Input = input.bool(true, "Band 7", inline = "bandPlots2", group = GRP_VISUAL,
     tooltip = "Show/hide Band 7 plot only. Calculations and optional deep flips still use the band")
showBand8Input = input.bool(true, "Band 8", inline = "bandPlots2", group = GRP_VISUAL,
     tooltip = "Show/hide Band 8 plot only. Calculations and optional deep flips still use the band")
showBand9Input = input.bool(true, "Band 9", inline = "bandPlots2", group = GRP_VISUAL,
