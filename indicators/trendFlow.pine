showBand10Input = input.bool(true, "Band 10", inline = "bandPlots2", group = GRP_VISUAL,
     tooltip = "Show/hide Band 10 plot only. Calculations and optional deep flips still use the band")
showBand11Input = input.bool(true, "Band 11", inline = "bandPlots3", group = GRP_VISUAL,
     tooltip = "Show/hide Band 11 plot only. Calculations and optional deep flips still use the band")
showBand12Input = input.bool(true, "Band 12", inline = "bandPlots3", group = GRP_VISUAL,
     tooltip = "Show/hide Band 12 plot only. Calculations and optional deep flips still use the band")
showBand13Input = input.bool(true, "Band 13", inline = "bandPlots3", group = GRP_VISUAL,
     tooltip = "Show/hide Band 13 plot only. Calculations and optional deep flips still use the band")
showBand14Input = input.bool(true, "Band 14", inline = "bandPlots3", group = GRP_VISUAL,
     tooltip = "Show/hide Band 14 plot only. Calculations and optional deep flips still use the band")
showBand15Input = input.bool(true, "Band 15", inline = "bandPlots3", group = GRP_VISUAL,
     tooltip = "Show/hide Band 15 plot only. Calculations and optional deep flips still use the band")
showBand16Input = input.bool(true, "Band 16", inline = "bandPlots4", group = GRP_VISUAL,
     tooltip = "Show/hide Band 16 plot only. Calculations and optional deep flips still use the band")
showBand17Input = input.bool(true, "Band 17", inline = "bandPlots4", group = GRP_VISUAL,
     tooltip = "Show/hide Band 17 plot only. Calculations and optional deep flips still use the band")
showBand18Input = input.bool(true, "Band 18", inline = "bandPlots4", group = GRP_VISUAL,
     tooltip = "Show/hide Band 18 plot only. Calculations and optional deep flips still use the band")
showBand19Input = input.bool(true, "Band 19", inline = "bandPlots4", group = GRP_VISUAL,
     tooltip = "Show/hide Band 19 plot only. Calculations and optional deep flips still use the band")
showBand20Input = input.bool(true, "Band 20", inline = "bandPlots4", group = GRP_VISUAL,
     tooltip = "Show/hide Band 20 plot only. Calculations, optional deepest flips, SL and trailing logic still use the band")

showHeatInput = input.bool(true, "Show Band Heatmap Fill", group = GRP_VISUAL,
     tooltip = "Gradient fill between bands (liquidity pressure zone)")

showTrendPnlInput = input.bool(false, "Show Trend P&L Tracker", group = GRP_VISUAL,
     tooltip = "Floating label that follows price in REAL TIME showing the\n" +
               "directional % move since the current trend started (flip bar\n" +
               "close), plus a dotted baseline at the trend start price.\n" +
               "Directional: a bear trend with falling price shows positive %.\n" +
               "Label turns red when the trend is under water")

showSignalsInput = input.bool(true, "Show Retest Signals", group = GRP_VISUAL,
     tooltip = "Diamond labels with quality score at retest entries")

showFlipLabelsInput = input.bool(true, "Show Flip Labels", group = GRP_VISUAL,
     tooltip = "▲/▼ labels at confirmed trend flips")

signalFontSizeInput = input.string("Small", "Signal Label Size",
     options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GRP_VISUAL,
     tooltip = "Font size for retest diamonds, flip labels and\n" +
               "trade entry markers (Long/Short)")

labelFontSizeInput = input.string("Small", "SL/TP Label Font Size",
     options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GRP_VISUAL,
     tooltip = "Font size for Entry/SL/TP labels")

// ── Risk Management ─────────────────────────────────────────
riskPresetInput = input.string("Balanced", "Risk Preset",
     options = ["Conservative", "Balanced", "Aggressive", "Scalping", "Custom"],
     group   = GRP_RISK,
     tooltip = "Quick risk presets:\n" +
               "• Conservative: Band 20 SL in ATR mode, trails after TP1\n" +
               "• Balanced: SL 1.5×ATR, TP 1R/2R/3R\n" +
               "• Aggressive: SL 1.0×ATR, TP 1.5R/2.5R/4R\n" +
               "• Scalping: SL 0.8×ATR, TP 0.8R/1.5R/2R\n" +
               "• Custom: use manual multipliers below\n"  +
               "Note: the SL part applies in ATR mode; Wick-Anchored mode\n" +
               "places SL from the signal bar wick instead")

slModeInput = input.string("Wick-Anchored", "SL Mode",
     options = ["Wick-Anchored", "ATR"],
     group   = GRP_RISK,
     tooltip = "How the stop-loss is placed at entry:\n" +
               "• Wick-Anchored: below/above the signal bar's wick + 0.25×ATR buffer\n" +
               "  (min distance 0.5×ATR enforced). Structure-aware, recommended\n" +
               "• ATR: fixed SL Multiplier × ATR distance from entry\n" +
               "  Conservative preset uses Band 20, then trails it after TP1")

atrLenRiskInput = input.int(14, "ATR Length (Risk)", minval = 5, maxval = 50, group = GRP_RISK,
     tooltip = "ATR period for stop-loss distance calculation.\n" +
               "• 14 = standard\n" +
               "• Lower = tighter stops\n" +
               "• Higher = wider stops")

slMultInput = input.float(1.5, "SL Multiplier (×ATR)", minval = 0.5, maxval = 5.0, step = 0.1,
     group   = GRP_RISK,
     tooltip = "Stop-loss distance as multiple of ATR (ATR mode, Custom preset).\n" +
               "• Scalping: 0.8-1.2\n" +
               "• Swing: 1.5-2.5")

tp1MultInput = input.float(1.0, "TP1 Multiplier (×Risk)", minval = 0.5, maxval = 5.0, step = 0.1,
     group   = GRP_RISK,
     tooltip = "Take-profit 1 as multiple of risk (SL distance).\n1.0 = 1:1 Risk:Reward")

tp2MultInput = input.float(2.0, "TP2 Multiplier (×Risk)", minval = 1.0, maxval = 10.0, step = 0.1,
     group   = GRP_RISK,
     tooltip = "Take-profit 2 as multiple of risk.\n2.0 = 1:2 Risk:Reward")

tp3MultInput = input.float(3.0, "TP3 Multiplier (×Risk)", minval = 1.5, maxval = 15.0, step = 0.1,
     group   = GRP_RISK,
     tooltip = "Take-profit 3 as multiple of risk.\n3.0 = 1:3 Risk:Reward")

beInput = input.bool(true, "Break-Even After TP1", group = GRP_RISK,
