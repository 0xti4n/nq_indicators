showStatsSecInput = input.bool(true, "  └ Stats section", group = GRP_DASH,
     tooltip = "Trades, W/L, Win Rate (+gauge), recent Form")

// ── Alerts ──────────────────────────────────────────────────
webhookInput = input.bool(false, "Webhook JSON Format", group = GRP_ALERT,
